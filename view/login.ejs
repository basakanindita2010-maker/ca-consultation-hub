<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CA Consultation Hub - Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body{
      min-height:100vh;
      background: linear-gradient(135deg,#0f172a,#1d4ed8);
      display:flex;
      align-items:center;
    }
    .card{
      border:none;
      border-radius:24px;
      box-shadow:0 20px 60px rgba(0,0,0,.25);
    }
    .brand{
      font-weight:800;
      letter-spacing:.4px;
    }
  </style>
</head>
<body>
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-5 col-md-8">
        <div class="card p-4 p-md-5 bg-white">
          <h2 class="brand text-dark mb-1">CA Consultation Hub</h2>
          <p class="text-muted mb-4">Book consultations, upload Form 16, calculate tax, and pay online.</p>

          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <ul class="nav nav-pills mb-3" id="authTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#loginPane" type="button">Login</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-bs-toggle="pill" data-bs-target="#registerPane" type="button">Register</button>
            </li>
          </ul>

          <div class="tab-content">
            <div class="tab-pane fade show active" id="loginPane">
              <form method="POST" action="/login" class="d-grid gap-3">
                <input class="form-control form-control-lg" type="email" name="email" placeholder="Email" required>
                <input class="form-control form-control-lg" type="password" name="password" placeholder="Password" required>
                <button class="btn btn-dark btn-lg">Login</button>
              </form>
            </div>

            <div class="tab-pane fade" id="registerPane">
              <form method="POST" action="/register" class="d-grid gap-3">
                <input class="form-control form-control-lg" name="name" placeholder="Full name" required>
                <input class="form-control form-control-lg" type="email" name="email" placeholder="Email" required>
                <input class="form-control form-control-lg" type="password" name="password" placeholder="Password" required>
                <input class="form-control form-control-lg" name="phone" placeholder="Phone number">
                <button class="btn btn-primary btn-lg">Create Account</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
